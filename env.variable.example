# Application
PORT=8080

# Database Configuration
# For Docker: DB_HOST=postgres (when running app in Docker)
# For Local Dev: DB_HOST=localhost (when running app locally with Docker DB)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=grievance

# JWT Configuration
JWT_SECRET=your-secret-key-change-this-in-production
JWT_EXPIRES_IN=1d